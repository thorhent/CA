<?xml version="1.0" encoding="UTF-8"?>
<interface domain="clinicalayudante">
  <requires lib="gtk" version="4.0"/>
  <requires lib="adw" version="1.0"/>
  <template class="CalculadoraWindow" parent="AdwApplicationWindow">
    <property name="default-width">800</property>
    <property name="default-height">500</property>
    <property name="title" translatable="yes">Calculadoras Clínicas</property>
    <child>
      <object class="AdwNavigationSplitView" id="split">
        <property name="collapsed">false</property>
        <property name="min-sidebar-width">280</property>

        <property name="sidebar">
          <object class="AdwNavigationPage">
            <property name="title" translatable="yes">Calculadoras</property>
            <property name="child">
              <object class="AdwToolbarView">
                <child type="top">
                  <object class="AdwHeaderBar">
                    <property name="show-end-title-buttons">false</property>
                    <property name="title-widget">
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">Calculadoras</property>

                      </object>
                    </property>
                  </object>
                </child>
                <property name="content">
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <child>
                      <object class="GtkSearchEntry" id="buscador">
                        <property name="margin-start">12</property>
                        <property name="margin-end">12</property>
                        <property name="margin-top">10</property>
                        <property name="margin-bottom">10</property>
                        <property name="placeholder-text" translatable="yes">Buscar calculadora...</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkScrolledWindow">
                        <property name="vexpand">true</property>
                        <property name="hscrollbar-policy">never</property>
                        <child>
                          <object class="GtkListBox" id="listaCalculadoras">
                            <property name="selection-mode">single</property>
                            <style>
                              <class name="navigation-sidebar"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </property>
          </object>
        </property>

        <property name="content">
          <object class="AdwNavigationPage">
            <property name="title" translatable="yes">Fórmula</property>

            <property name="child">
              <object class="AdwToolbarView">
                <child type="top">
                  <object class="AdwHeaderBar"/>
                </child>
                <property name="content">
                  <object class="GtkStack" id="stackCalculadoras">
                    <property name="hexpand">true</property>
                    <property name="vexpand">true</property>
                    <property name="transition-type">crossfade</property>
                    <child>
                      <object class="AdwStatusPage" id="pagina_inicio">
                        <property name="name">inicio</property>
                        <property name="title" translatable="yes">Bienvenido</property>
                        <property name="description" translatable="yes">Seleccione una calculadora en el panel izquierdo.</property>
                        <property name="icon-name">accessories-calculator-symbolic</property>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </property>
          </object>
        </property>
      </object>
    </child>
  </template>
</interface>
